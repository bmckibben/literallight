<div class="main-margined" id="blog">
<div class="row">
<div class="col-md-12">



<%= form_for(@blog) do |f| %>
<h1>Goal for <%= if @blog.entry_for.nil? then @entry_for else @blog.entry_for end %></h1>
  <% if @blog.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@blog.errors.count, "error") %> prohibited this blog from being saved:</h2>

      <ul>
      <% @blog.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

<div class="row">
  <div class="col-md-6 col-md-offset-3 col-sm-12 ">
      <div class="panel panel-default">
          <div class="panel-heading">
            <%= f.label :entry_for %><br>
            <%= f.text_field :entry_for, :style => "width:100%;" %>
          </div>      
          <div class="panel-body">
              <div class="field">
                <%= f.text_area :goals, rows: 25 %>
              </div>
          </div>
      </div> 
  </div>
</div>

<div class="row">
  <div class="actions col-md-6 col-md-offset-3 col-sm-12"> 

    <%= f.submit "Save" , class: "btn btn-primary pull-right" %> 
    <%= link_to "Cancel" , blogs_path , class: "btn btn-danger" %> 
  </div>
</div>  
<% end %>


</div>
</div>
</div>