<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<%= favicon_link_tag 'favicon.ico' %> 
<title>LiteralLight</title>
<meta name="description" content="">
<meta name="author" content="">

  <%= stylesheet_link_tag    'application', media: 'all' %>
  <%= javascript_include_tag 'application' %>
  <%= csrf_meta_tags %>
<link href='http://fonts.googleapis.com/css?family=Open+Sans:400,700,800,600,300' rel='stylesheet' type='text/css'>

</head>
<body id="page-top" data-spy="scroll" data-target=".navbar-fixed-top">
<div id="preloader">
  <div id="status"><%= image_tag("preloader.gif", size: "64", alt: "") %> </div>
</div>
<!-- Navigation -->
<nav class="navbar navbar-custom navbar-fixed-top" role="navigation">
  <div class="container">
    <div class="navbar-header">
      <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-main-collapse"><i class="fa fa-bars"></i></button>
      <%= link_to image_tag("literallight_txt.png"), "#page-top", class: "navbar-brand page-scroll" %>
    </div>
    
    <!-- Collect the nav links, forms, and other content for toggling -->
    <div class="collapse navbar-collapse navbar-right navbar-main-collapse">
      <ul class="nav navbar-nav">
        <!-- Hidden li included to remove active class from about link when scrolled up past about section -->
        <li class="hidden"> <a href="#page-top"></a> </li>
        <li> <a class="page-scroll" href="#about">About</a> </li>
        <li> <a class="page-scroll" href="#services">Competencies</a> </li>
        <li> <a class="page-scroll" href="#works">Portfolio</a> </li>
        <li> <a class="page-scroll" href="#team">Team</a> </li>
        <li> <a class="page-scroll" href="#testimonials">Testimonials</a> </li>
        <li> <a class="page-scroll" href="#contact">Contact</a> </li>
        <% if user_signed_in? %>
            <li><%= link_to 'Sign out', destroy_user_session_path, method: :delete %></li>
        <% else %>
            <li><%= link_to 'Login', new_user_session_path %></li>
        <% end %>        
      </ul>
    </div>
    <!-- /.navbar-collapse --> 
  </div>
  <!-- /.container --> 
</nav>

<!-- Header -->
<div id="intro">
  <div class="intro-body">
    <div class="container">
      <div class="row">
        <div class="col-md-10 col-md-offset-1">
          <h1><span class="brand-heading">LiteralLight</span></h1>
          <p class="intro-text">The professional website of Ben McKibben</p>
          <a href="#about" class="btn btn-primary page-scroll">Learn More</a> </div>
      </div>
    </div>
  </div>
</div>
<!-- About Section -->
<div id="about">
  <div class="container">
    <div class="section-title text-center center">
      <h2>About</h2>
      <hr>
    </div>
    <div class="row">
      <div class="col-md-4"><%= image_tag("switching03.jpg", class: "img-responsive" ) %></div>
      <div class="col-md-4">
        <div class="about-text">
          <h4>Who I Am</h4>
          <p>An experienced full stack web application developer.</p>
          <p>I am a puzzle solver. I have the ability to create component parts and assemble them so they work in the most efficient way.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="about-text">
          <h4>This Website</h4>
          <p>This is a showcase of my technical expertise using:</p>
          <ul>
              <li>Ruby <%= RUBY_VERSION %></li>
              <li>Rails <%= Rails.version %></li>
              <li>MongoDB/Mongoid</li>
              <li>jQuery</li>
              <li>Twitter Bootstrap</li> 
              <li>Devise</li>
              <li>Pundit</li>     
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- Services Section -->
<div id="services" class="text-center">
  <div class="container">
    <div class="section-title center">
      <h2>Competencies</h2>
      <hr>
    </div>
    <div class="space"></div>
    <div class="row">
      <div class="col-md-3 col-sm-6">
        <div class="service"> <i class="fa fa-desktop"></i>
          <h3>HTML</h3>
          <p>I&apos;ve worked with all of its variations.</p>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="service"> <i class="fa fa-cogs"></i>
          <h3>Javascript</h3>
          <p>jQuery and AngularJS.</p>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="service"> <i class="fa fa-tablet"></i>
          <h3>CSS</h3>
          <p>Twitter Bootstrap is great!</p>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="service"><i class="fa fa-html5"></i>
          <h3>Ruby On Rails</h3>
          <p>My newest addition to my toolkit.</p>
        </div>
      </div>
    </div>
    <div class="space"></div>
    <div class="row">
      <div class="col-md-3 col-sm-6">
        <div class="service"><i class="fa fa-wordpress"></i>
          <h3>Coldfusion</h3>
          <p>My staple for fifteen years.</p>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="service"><i class="fa fa-bullhorn"></i>
          <h3>Database</h3>
          <p>Oracle, MS-SQLServer, MongoDB, PostgreSQL, MySQL</p>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="service"><i class="fa fa-rocket"></i>
          <h3>R &amp; R Studio</h3>
          <p>Used in recent coursework learning Big Data and Machine Learning.</p>
        </div>
      </div>
    </div>
  </div>
</div>
