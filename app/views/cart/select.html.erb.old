  <div class="row-fluid" style="margin-bottom:1em;">
    <div class="span12">
      <h3>
          <% if @fh_details != nil && @fh_details["fa_deceased_name"] != "" %>
            <span style="color:#8D8777;">Share your condolences with the family of</span>&nbsp;<%= @fh_details["fa_deceased_name"] %>
          <% else %> 
            <span style="color:#8D8777;">Share your condolences</span>
          <% end %>
      </h3>
    </div>
  </div>
  <% if @fh_details != nil && @fh_details["o_id"] != "" %>
  <div class="row-fluid" style="margin-bottom:1em;">
    <div class="span11" align="right">
      <%= link_to "VIEW OBITUARY", cart_obit_path(:o_id => @fh_details["o_iD"], :deceased_name => @fh_details["fa_deceased_name"]), :remote => true, :class => "greenBtn3 aPopup", :style => "width:206px;height:40px;float:right;"  %> 
    </div>
  </div>
  <% end %>
 <div class="row-fluid" style="max-width:700px;">
    <% @active_products.each do |product| %>
      <div class="selectCard" data-id="pop<%= product.product_id %>">

        <%= link_to "Preview", cart_detail_path(:product_id => product.product_id), :remote => true, :class => "grayBtn4 trigger aPopup", :style => "display:none;", :id => "pop#{product.product_id}" %> 
        <%= link_to image_tag(asset_path("cart/products/thumb/"+product.thumbnail), :alt => "Click to Personalize", :title => "Click to Personalize", :class => "selectThumb"), cart_personalize_path(:product_id => product.product_id) %> 

        <div style="margin-top:195px; width: 163px; text-align: center;">
          <%= link_to "Select", cart_personalize_path(:product_id => product.product_id), :class => "greenLink" %>
        </div>
      </div>  
    <% end %>
</div>
<% if @fh_details != nil && @fh_details["o_id"] != "" %>
  <div class="row-fluid" style="margin-bottom:1em;">
    <div class="span11">
      <%= link_to "VIEW OBITUARY", cart_obit_path(:o_id => @fh_details["o_iD"] ), :remote => true, :class => "greenBtn3 aPopup", :style => "width:206px;height:40px;float:right;" %> 
    </div>
  </div>
<% end %>
