<div class="row">
<div class="col-md-12">
<p id="notice"><%= notice %></p>

<h1>Musings</h1>

<table>
  <thead>
    <tr>
      <th>Date</th>
      <th>Note</th>
      <th>&nbsp;</th>
    </tr>
  </thead>

  <tbody>
    <% @journals.each do |journal| %>
      <tr>
        <td><%= journal.entry_for.to_formatted_s(:stardate) %></td>
        <td><%= journal.notes %></td>
        <td><%= link_to 'Edit', edit_journal_path(journal), class: "btn btn-primary btn-xs" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to "Home" , journal_path , class: "btn btn-primary" %> 

</div>
</div>