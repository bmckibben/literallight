<div class="main-margined">
<div class="row">
<div class="col-md-12">
<p id="notice"><%= notice %></p>

<h1>Musings</h1>

<div class="table-responsive">
<table class="table reqponsive-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Note</th>
      <th>&nbsp;</th>
    </tr>
  </thead>

  <tbody>
    <% @journals.each do |journal| %>
      <tr>
        <td style="width:50px;"><%= link_to journal.entry_for, journals_show_musing_path(id: :journal.id),  class: "btn btn-default btn-xs"  %></td>
        <td><%= journal.notes %></td>
        <td style="width:50px;"><%= link_to 'Edit', edit_journal_path(journal), class: "btn btn-primary btn-xs" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
<br>

<%= link_to "Home" , home_path , class: "btn btn-primary" %> 

</div>
</div>
</div>