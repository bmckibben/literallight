<div class="main-margined">
  <div class="row">
    <div class="col-md-12">
      <% if notice %>
      <div class="alert alert-warning alert-dismissible" role="alert">
      <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true" class="glyphicon glyphicon-remove-circle"></span></button>
      <p id="notice"><%= notice %></p>
      </div>
      <% end %>
    </div>
  </div>
  <div class="row">
    <div class="col-md-10 col-md-offset-1 col-sm-12">
    <%= link_to 'New Journal', new_journal_path, class: "btn btn-primary pull-right" %>
    <h1>Entries</h1>
    Today is <%= DateTime.now.in_time_zone('Indiana (East)').to_formatted_s(:stardate) %>
    </div>
  </div>
<% @journals.each do |journal| %>
  <div class="row">
    <div class="col-md-10 col-md-offset-1 col-x-12" style="border-top:1px solid #fff">
      <h2><%= link_to journal.entry_for, edit_journal_path(journal) %></h2>
      <h3>Goals</h3>
      <p><%= journal.goals.to_s %></p>
      <h3>Notes</h3>
      <p><%= journal.notes.to_s %></p>
    </div>
  </div>
  <div class="row">
    <div class="field col-md-1 col-sm-12">
      Weight<br>
      <%= journal.weight.to_s %>
    </div>  
    <div class="field col-md-1 col-sm-12">
      Body Fat<br>
      <%= journal.body_fat.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      Systolic<br>
      <%= journal.systolic.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      Diastolic<br>
      <%= journal.diastolic.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      AM Glucose<br>
      <%= journal.am_glucose.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      &nbsp;
    </div>    
  </div>
  <div class="row">
    <div class="field col-md-1 col-md-offset-3 col-sm-12">
      Curls<br>
      <%= journal.curls.to_s %>
    </div>  
    <div class="field col-md-1 col-sm-12">
      KettleBells<br>
      <%= journal.kettlebells.to_s %>
    </div>  
    <div class="field col-md-1 col-sm-12">
      Situps<br>
      <%= journal.situps.to_s %>
    </div> 
    <div class="field col-md-1 col-sm-12">
      Pushups<br>
      <%= journal.pushups.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      Eliptical Time<br>
      <%= journal.eliptical_time.to_s %>
    </div> 
    <div class="field col-md-1 col-sm-12">
      Eliptical Dist<br>
      <%= journal.eliptical_dist.to_s %>
    </div>  
  </div>
  <div class="row">
    <div class="field col-md-1 col-md-offset-3 col-sm-12">
      Meditation<br>
      <%= journal.meditation.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      Yoga<br>
      <%= journal.yoga.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      Energy<br>
      <%= journal.energy.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      Motivation<br>
      <%= journal.motivation.to_s %>
    </div>
    <div class="field col-md-1 col-sm-12">
      Happiness<br>
      <%= journal.happiness.to_s %>
    </div>  
    <div class="field col-md-1 col-sm-12">
      &nbsp;
    </div>   
  </div>
<% end %>
</div>
