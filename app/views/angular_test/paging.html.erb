<div class="main-margined">
<div class="row">
<div class="col-md-10 col-md-offset-1 col-sm-12">
<article data-ng-app="musings" ng-appcontroller="MusingSearchController">
<h1>Musings</h1>


<div class="search-form panel panel-default" >
<div class="panel-body">
  <form>
    <div class="input-group inpug-group-lg">
      <label for="searchwords" class="sr-only">Searchwords</label> 
      <input type="text" 
        name="searchwords" 
        placeholder="Search Words"
        class="form-control input-md" 
        ng-model="searchwords">
      <span class="input-group-btn">
        <button class="btn btn-primary btn-lg" 
          ng-click="search(searchwords)">
          Find Musings
        </button>  
      </span>  
    </div>
  </form>
</div>  
</div>
<p class="searchedFor" ng-if="searchedFor">
<small> Searched for:</small> {{searchedFor}}
</p>


</article>

<article data-ng-app="angular_test">
  <header>
    <h1 ng-if="name">Hello, {{name}}</h1>
  </header>
  <section>
  <form class="form-inline">
    <div class="form-group">
    <label for="name">Name</label>
    <input class="form-control"
    name="name"
    type="text"
    placeholder="Enter your name"
    autofocus
    ng-model="name">
    </div>
  </form>
  </section>
</article>

</div>
</div>
</div>
