

<table class="table">
  <thead>
    <tr>
      <th>Product</th>
      <th>Title</th>
      <th>Description</th>
      <th>Status</th>
      <th>Display order</th>
      <th>Image</th>
      <th>Retail price</th>
      <th>Link</th>
      <th>Author last</th>
      <th>Author first</th>
      <th>Publish year</th>
      <th>Genre</th>
      <th>Keyword</th>
      <th>Rating</th>
      <th>Hugo</th>
      <th>Nebula</th>
      <th>Show</th>
      <th>Edit</th>
      <th>Remove</th>
    </tr>
  </thead>

  <tbody>
    <% @products.each do |product| %>
      <tr>
        <td><%= product.product_id %></td>
        <td><%= product.title %></td>
        <td><%= product.description %></td>
        <td><%= product.status %></td>
        <td><%= product.display_order %></td>
        <td><%= product.image %></td>
        <td><%= product.retail_price %></td>
        <td><%= product.link %></td>
        <td><%= product.author_last %></td>
        <td><%= product.author_first %></td>
        <td><%= product.publish_year %></td>
        <td><%= product.genre %></td>
        <td><%= product.keyword %></td>
        <td><%= product.rating %></td>
        <td><%= product.hugo %></td>
        <td><%= product.nebula %></td>
        <td><%= link_to raw('<i class="icon-eye-open icon-white"></i>'), product %></td>
        <td><%= link_to raw('<i class="icon-pencil icon-white"></i>'), edit_product_path(product) %></td>
        <td><%= link_to raw('<i class="icon-remove-sign icon-white"></i>'), product, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Product', new_product_path,  class: "btn btn-default" %>
