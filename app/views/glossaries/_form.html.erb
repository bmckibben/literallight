<%= form_for(@glossary) do |f| %>
  <% if @glossary.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@glossary.errors.count, "error") %> prohibited this glossary from being saved:</h2>

      <ul>
      <% @glossary.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

<div class="row">
  <div class="field col-md-6 col-md-offset-3 col-sm-12">
    <%= f.label :word %><br>
    <%= f.text_field :word %>
  </div>

  <div class="field col-md-3 col-sm-12">
    <%= f.label :display %><br>
    <%= f.text_field :display %>
  </div>
</div>

<div class="row">
  <div class="field col-md-9 col-md-offset-3 col-sm-12">  
    <%= f.label :definition %><br>
    <%= f.text_area :definition %>
  </div>
</div>

<div class="row">
  <div class="actions col-md-6 col-md-offset-3 col-sm-12"> 
    <%= f.submit "Save" , class: "btn btn-primary pull-right" %> 
    <%= link_to "Cancel" , glossaries_path , class: "btn btn-danger" %> 
  </div>
</div>  
<% end %>
